# SMTP Configuration
# Keep sensitive data like passwords and usernames here.
# Non-sensitive settings (Host, Port, Encryption, Names, etc.) can be managed in settings.toml.
SMTP_USERNAME=
SMTP_PASSWORD=

# AI Research API Keys
GEMINI_API_KEY=
OPENAI_API_KEY=

# Email validation API key
# NeverBounce is the only supported external validation provider.
# Used at the timing selected by EXTERNAL_VALIDATION_STAGE in settings.toml.
# Every NeverBounce check is a single-address request, not a bulk job.
# Use the API key from your NeverBounce Custom Integration.
NEVERBOUNCE_API_KEY=
