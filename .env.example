# SMTP Configuration
# Keep sensitive data like passwords and usernames here.
# Non-sensitive settings (Host, Port, Encryption, Names, etc.) can be managed in settings.toml.
SMTP_USERNAME=
SMTP_PASSWORD=

# AI Research API Keys
GEMINI_API_KEY=
OPENAI_API_KEY=

# Email validation API Keys
# With EXTERNAL_VALIDATION_SERVICE="auto", adding one of these keys is enough.
# Use ZEROBOUNCE_API_KEY for ZeroBounce or NEVERBOUNCE_API_KEY for NeverBounce.
ZEROBOUNCE_API_KEY=
NEVERBOUNCE_API_KEY=
# Optional legacy fallback if the selected service-specific key is empty.
EXTERNAL_VALIDATION_API_KEY=
